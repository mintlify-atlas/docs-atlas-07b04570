  "keyFeatures": [
    "Network thermal printer management via TCP/IP, USB, and IPP protocols",
    "Real-time scale data capture from serial ports with WebSocket broadcasting",
    "JSON-based template system for customizable receipt and document layouts",
    "Windows Service for background operation and system tray management",
    "Cross-platform MAUI application for Android and Windows configuration",
    "ESC/POS command generation for thermal and dot-matrix printers",
    "WebSocket server on port 7000 for POS system integration",
    "Multi-printer support with copy-to functionality"
  ],
